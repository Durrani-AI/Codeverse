# Codeverse - Environment Variables
# Copy to .env and fill in your values.

# Application
APP_NAME="Codeverse"
DEBUG=False
HOST=0.0.0.0
PORT=8000

# CORS (JSON array – add your frontend URL)
ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:3000","http://localhost:3001"]

# Database
# Local:   sqlite+aiosqlite:///./interview_platform.db
# Cloud:   postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./interview_platform.db

# JWT (use a strong random key in production)
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Provider: "ollama" (local) or "groq" (cloud)
AI_PROVIDER=ollama

# Ollama (local development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=120

# Groq (cloud – get key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Interview
MAX_INTERVIEW_DURATION_MINUTES=60
MIN_INTERVIEW_DURATION_MINUTES=15
DEFAULT_QUESTIONS_COUNT=5

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
